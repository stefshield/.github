root = true

# Defaults for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
max_line_length = 120
trim_trailing_whitespace = true
insert_final_newline = true

# YAML
[*.{yml,yaml}]
# no line length enforcement (long URLs and values are common)
max_line_length = off

# Markdown
[*.md]
# preserve trailing whitespace (two spaces = line break)
trim_trailing_whitespace = false
# no line length enforcement (prose and URLs should not be wrapped)
max_line_length = off
