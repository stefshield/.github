# StefShield Java (Maven + Gradle) .gitignore template
#
# Reference template for Java projects.
# Copy this file to the root of your repository and rename it to .gitignore.

# Compiled output
*.class
*.jar
*.war
*.ear

# Maven
target/
pom.xml.*

# Gradle
.gradle/
build/

# Logs
*.log
logs/

# Environment variables (secrets)
.env
.env.*
!.env.example

# IDEs
.idea/
*.iml
out/
.classpath
.project
.settings/
bin/
.vscode/

# OS / Editor noise
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.tmp
